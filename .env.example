# SignSpeak environment template.
# Copy to .env and fill in real values. Do NOT commit .env.

# Domain
# In production, set to the public domain — used by Traefik for TLS provisioning.
DOMAIN=localhost
# To test the local Traefik config:
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend.
FRONTEND_HOST=http://localhost:5173
# In staging and production, set to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
# In staging/production, the backend refuses to boot with default secrets below.
ENVIRONMENT=local

PROJECT_NAME="SignSpeak"
STACK_NAME=signspeak

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
# Generate with: openssl rand -hex 32
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Emails (leave SMTP_HOST blank to disable email sending)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# PostgreSQL — choose ONE path:
#  (a) Local / CI: leave DATABASE_URL empty and use the POSTGRES_* settings
#      below. `docker compose up` starts a bundled `db` service with these
#      credentials (see compose.override.yml). No SSL is used.
#  (b) Hosted provider (e.g. Supabase): set DATABASE_URL to the connection
#      string and leave POSTGRES_* blank. DATABASE_URL takes precedence and
#      enforces sslmode=require.
DATABASE_URL=

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Sentry DSN (optional; only used when ENVIRONMENT != local)
SENTRY_DSN=

# Docker image names (override when pushing to your own registry)
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ML model paths (absolute, inside the backend container or local machine).
# Inside Docker, models live at /app/backend/models/* (see compose.yml volumes).
KOKORO_MODEL_PATH="/app/backend/models/kokoro-v1.0.onnx"
KOKORO_VOICES_PATH="/app/backend/models/voices-v1.0.bin"
