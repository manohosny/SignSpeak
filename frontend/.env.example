# SignSpeak frontend environment template.
# Copy to frontend/.env and adjust for your local setup. Do NOT commit frontend/.env.
#
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Base URL of the backend API. In Docker builds this is injected as a build
# arg (see frontend/Dockerfile and compose.yml); for local `vite dev` it is
# read from this file.
VITE_API_URL=http://localhost:8000

# MailCatcher web UI — used by the Playwright e2e suite to read test emails.
MAILCATCHER_HOST=http://localhost:1080
